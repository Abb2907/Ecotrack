# EcoTrack Frontend Public Environment Variables Configuration
# Prefixed with NEXT_PUBLIC_ to expose to the browser.

# Firebase Client SDK Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ecotrack-prod-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ecotrack-prod-2026
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_number:web:your_app_id_here

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
