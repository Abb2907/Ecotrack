# EcoTrack Backend Environment Variables Configuration
# Do not commit actual secrets to version control.

# Google Cloud Platform Configurations
PROJECT_ID=ecotrack-prod-2026
REGION=us-central1
ENVIRONMENT=development  # development | production

# Vertex AI config
VERTEX_AI_LOCATION=us-central1

# Secret Manager resource identifiers
ANONYMIZATION_KEY_SECRET_NAME=anonymization-hmac-key

# Service Port Configuration
PORT=8000
